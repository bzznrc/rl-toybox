{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Snake - Play User",
      "type": "debugpy",
      "request": "launch",
      "python": "${workspaceFolder}/../GameEnv/Scripts/python.exe",
      "module": "scripts.play_user",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "args": [
        "--game",
        "snake",
        "--level",
        "${input:playLevel}"
      ]
    },
    {
      "name": "Snake - Play AI",
      "type": "debugpy",
      "request": "launch",
      "python": "${workspaceFolder}/../GameEnv/Scripts/python.exe",
      "module": "scripts.play_ai",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "args": [
        "--game",
        "snake",
        "--level",
        "${input:playLevel}",
        "--render"
      ]
    },
    {
      "name": "Snake - Train AI",
      "type": "debugpy",
      "request": "launch",
      "python": "${workspaceFolder}/../GameEnv/Scripts/python.exe",
      "module": "scripts.train",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "args": [
        "--game",
        "snake",
        "--resume",
        "${input:trainResumeMode}"
      ]
    },
